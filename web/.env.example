# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY

# API publica consumida por clientes, quando necessario
NEXT_PUBLIC_API_URL=http://localhost:3000

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxx
# URL pública do webhook. Em produção:
# https://seudominio.com/api/webhooks/mercadopago
MERCADOPAGO_WEBHOOK_URL=https://seudominio.com/api/webhooks/mercadopago

# Opcional: assinatura secreta do webhook, se configurada no Mercado Pago
MERCADOPAGO_WEBHOOK_SECRET=

# As credenciais também podem ser configuradas pelo painel:
# /admin/configuracoes/pagamentos
# Quando configuradas no painel, os segredos ficam criptografados no Supabase Vault.
