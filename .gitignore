# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/web/node_modules
/mobile/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/web/.next/
/out/
/web/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!backend/.env.example
!web/.env.example
!mobile/.env.example

# vercel
.vercel
/web/.vercel

# expo
/mobile/.expo

# logs and generated reports
*.log
/web/playwright-report
/web/test-results
/web/db/test-results

# typescript
*.tsbuildinfo
next-env.d.ts
.next
.vercel
